@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

title Nível 4: Diagrama de Código

LAYOUT_TOP_DOWN()
skinparam classAttributeIconSize 0

Container_Boundary(agendamento_component, "Componente: Agendamento") {

    class AgendamentoController {
      +criarAgendamento(dados)
      +cancelarAgendamento(id)
      +reagendarAgendamento(id, novaDataHora)
      +atualizarStatus(id, status)
    }

    class AgendamentoService {
      +criar(dados)
      +cancelar(id)
      +reagendar(id, novaDataHora)
      +atualizarStatus(id, status)
      +validarConflito(dataHora, duracaoMin)
    }

    class AgendamentoRepository {
      +salvar(agendamento)
      +buscarPorId(id)
      +buscarPorDataHora(dataHora)
      +atualizar(agendamento)
    }

    class Agendamento {
      -id : int
      -cliente_id : int
      -pet_id : int
      -servico_id : int
      -data_hora : String
      -status : String
      -observacoes : String
    }

    class Servico {
      -id : int
      -nome : String
      -duracao_min : int
      -preco : float
      -descricao : String
    }

    class Pet {
      -id : int
      -cliente_id : int
      -nome : String
      -especie : String
      -raca : String
      -porte : String
      -observacoes : String
    }

    class Cliente {
      -id : int
      -nome : String
      -telefone : String
      -email : String
    }
}

class BancoDeDados <<database>> {
  SQLite
}

AgendamentoController --> AgendamentoService : usa
AgendamentoService --> AgendamentoRepository : usa
AgendamentoService --> Servico : consulta
AgendamentoService --> Pet : valida
AgendamentoService --> Cliente : valida
AgendamentoRepository --> Agendamento : persiste
AgendamentoRepository --> BancoDeDados : SQL

@enduml
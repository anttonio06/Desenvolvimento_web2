<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clientes - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">


    <% if (sucesso === 'editado') { %>
      <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> Cliente atualizado com sucesso!
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-people-fill"></i> Clientes</div>
        <div class="page-subtitle">Gerencie os clientes do pet shop</div>
      </div>
      <button class="btn-primary-action" data-bs-toggle="modal" data-bs-target="#modalNovoCliente">
        <i class="bi bi-plus-lg"></i> Novo Cliente
      </button>
    </div>

    <div class="section-card">
      <div class="search-bar">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar cliente por nome, email ou telefone..." id="busca-cliente">
      </div>

      <table class="table-agendamentos" id="tabela-clientes">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Pets</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (clientes.length === 0) { %>
            <tr>
              <td colspan="6">
                <div class="empty-state">
                  <i class="bi bi-people"></i>
                  Nenhum cliente cadastrado ainda.
                </div>
              </td>
            </tr>
          <% } else { %>
            <% clientes.forEach(function(c, i) { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= c.nome %></strong></td>
                <td><%= c.telefone || '-' %></td>
                <td><%= c.email || '-' %></td>
                <td>
                  <% if (c.total_pets > 0) { %>
                    <span style="display:inline-flex; align-items:center; gap:5px; font-size:0.78rem; font-weight:600; color:#10b981; background:rgba(16,185,129,0.1); padding:3px 10px; border-radius:20px">
                      <i class="bi bi-heart-fill" style="font-size:0.65rem"></i> <%= c.total_pets %>
                    </span>
                  <% } else { %>
                    <span style="font-size:0.78rem; color:#374151">—</span>
                  <% } %>
                </td>
                <td class="acoes">
                  <button class="btn-acao editar" title="Editar" onclick="abrirEditar(<%= JSON.stringify({id: c.id, nome: c.nome, telefone: c.telefone || '', email: c.email || '', nomes_pets: c.nomes_pets || ''}) %>)"><i class="bi bi-pencil-fill"></i></button>
                  <button class="btn-acao excluir" title="Excluir" onclick="excluir('/clientes/<%= c.id %>')"><i class="bi bi-trash-fill"></i></button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>

    </div>

  </main>

  <!-- Modal Novo Cliente -->
  <div class="modal fade" id="modalNovoCliente" tabindex="-1" aria-labelledby="modalNovoClienteLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalNovoClienteLabel"><i class="bi bi-person-plus-fill me-2"></i>Novo Cliente</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div id="novo-erro" class="alert alert-danger d-none"></div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
            <input type="text" id="novo-nome" class="form-control" placeholder="Nome completo">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Telefone <span class="text-danger">*</span></label>
            <input type="text" id="novo-telefone" class="form-control" placeholder="(00) 00000-0000">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">E-mail <span class="text-danger">*</span></label>
            <input type="text" id="novo-email" class="form-control" placeholder="email@exemplo.com">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-success" onclick="cadastrarCliente()">Cadastrar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Editar Cliente -->
  <div class="modal fade" id="modalEditarCliente" tabindex="-1" aria-labelledby="modalEditarClienteLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="modalEditarClienteLabel"><i class="bi bi-pencil-fill me-2"></i>Editar Cliente</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div id="edit-erro" class="alert alert-danger d-none"></div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
            <input type="text" id="edit-nome" class="form-control" placeholder="Nome completo">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Telefone <span class="text-danger">*</span></label>
            <input type="text" id="edit-telefone" class="form-control" placeholder="(00) 00000-0000">
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">E-mail <span class="text-danger">*</span></label>
            <input type="email" id="edit-email" class="form-control" placeholder="email@exemplo.com">
          </div>
          <hr style="border-color:rgba(255,255,255,0.07);margin:18px 0 14px">
          <div style="font-size:0.7rem;font-weight:700;color:#10b981;text-transform:uppercase;letter-spacing:0.08em;margin-bottom:10px">
            <i class="bi bi-heart-fill"></i> Pets cadastrados
          </div>
          <div id="edit-pets-lista"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="button" class="btn btn-primary" onclick="salvarEdicao()">Salvar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Confirmação Exclusão -->
  <div class="modal fade" id="modalConfirmar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
      <div class="modal-content" style="border-radius:14px; border:1px solid rgba(239,68,68,0.2); background:#0f1624">
        <div class="modal-body p-4">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px">
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(239,68,68,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0">
              <i class="bi bi-exclamation-triangle-fill" style="color:#f87171; font-size:1.1rem"></i>
            </div>
            <h5 style="margin:0; font-size:1rem; font-weight:700; color:#f1f5f9">Confirmar exclusão</h5>
          </div>
          <p style="margin:0; font-size:0.875rem; color:#94a3b8; line-height:1.6">Deseja realmente excluir este cliente? Esta ação não pode ser desfeita.</p>
        </div>
        <div class="modal-footer border-0 pt-0 px-4 pb-4" style="gap:10px">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="flex:1">Cancelar</button>
          <button type="button" class="btn btn-danger" id="btnConfirmarExcluir" style="flex:1">Excluir</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    var clienteEditandoId = null;
    var _urlExcluir = null;
    var _modalConfirmar = null;

    function mascaraTelefone(valor) {
      var nums = valor.replace(/\D/g, '').slice(0, 11);
      if (nums.length === 0) return '';
      if (nums.length <= 2) return '(' + nums;
      if (nums.length <= 7) return '(' + nums.slice(0,2) + ') ' + nums.slice(2);
      return '(' + nums.slice(0,2) + ') ' + nums.slice(2,7) + '-' + nums.slice(7);
    }

    document.getElementById('novo-telefone').addEventListener('input', function() {
      var cursor = this.selectionStart;
      var antigo = this.value;
      this.value = mascaraTelefone(antigo);
    });

    document.getElementById('edit-telefone').addEventListener('input', function() {
      this.value = mascaraTelefone(this.value);
    });

    function mostrarErroNovo(msg) {
      var el = document.getElementById('novo-erro');
      el.textContent = msg;
      el.classList.remove('d-none');
    }

    function mostrarErroEdit(msg) {
      var el = document.getElementById('edit-erro');
      el.textContent = msg;
      el.classList.remove('d-none');
    }

    document.getElementById('modalNovoCliente').addEventListener('show.bs.modal', function() {
      document.getElementById('novo-nome').value = '';
      document.getElementById('novo-telefone').value = '';
      document.getElementById('novo-email').value = '';
      document.getElementById('novo-erro').classList.add('d-none');
    });

    function cadastrarCliente() {
      var nome = document.getElementById('novo-nome').value.trim();
      var telefone = document.getElementById('novo-telefone').value.trim();
      var email = document.getElementById('novo-email').value.trim();
      var telPattern = /^\(\d{2}\) \d{5}-\d{4}$/;
      var emailPattern = /^[^\s@]+@[^\s@]+\.(com|com\.br|net|org)$/;

      document.getElementById('novo-erro').classList.add('d-none');

      if (!nome) return mostrarErroNovo('Informe o nome do cliente.');
      if (!telefone) return mostrarErroNovo('Informe o telefone do cliente.');
      if (!telPattern.test(telefone)) return mostrarErroNovo('Telefone inválido. Use o formato (XX) XXXXX-XXXX.');
      if (!email) return mostrarErroNovo('Informe o e-mail do cliente.');
      if (!emailPattern.test(email)) return mostrarErroNovo('E-mail inválido. Use um e-mail terminado em .com, .com.br, .net ou .org.');

      fetch('/clientes', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome: nome, telefone: telefone, email: email })
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) {
          location.reload();
        } else if (data.erro === 'telefone_duplicado') {
          mostrarErroNovo('Esse telefone já está cadastrado para outro cliente.');
        } else if (data.erro === 'email_duplicado') {
          mostrarErroNovo('Esse e-mail já está cadastrado para outro cliente.');
        } else {
          mostrarErroNovo('Erro ao cadastrar. Tente novamente.');
        }
      });
    }

    document.getElementById('busca-cliente').addEventListener('input', function() {
      var termo = this.value.toLowerCase();
      document.querySelectorAll('#tabela-clientes tbody tr').forEach(function(tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    });

    function abrirEditar(cliente) {
      clienteEditandoId = cliente.id;
      document.getElementById('edit-nome').value = cliente.nome;
      document.getElementById('edit-telefone').value = mascaraTelefone(cliente.telefone);
      document.getElementById('edit-email').value = cliente.email;
      document.getElementById('edit-erro').classList.add('d-none');

      var petsLista = document.getElementById('edit-pets-lista');
      petsLista.innerHTML = '<div style="color:#4b5563;font-size:0.82rem;padding:6px 0">Carregando...</div>';

      new bootstrap.Modal(document.getElementById('modalEditarCliente')).show();

      fetch('/clientes/' + cliente.id + '/pets')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var pets = data.pets || [];
          if (pets.length === 0) {
            petsLista.innerHTML = '<div style="font-size:0.82rem;color:#4b5563;padding:6px 0"><i class="bi bi-heart" style="margin-right:5px"></i>Nenhum pet cadastrado.</div>';
            return;
          }
          petsLista.innerHTML = pets.map(function(p) {
            var detalhes = [p.especie];
            if (p.raca) detalhes.push(p.raca);
            if (p.porte) detalhes.push(p.porte);
            return '<div style="display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(16,185,129,0.06);border:1px solid rgba(16,185,129,0.12);border-radius:10px;margin-bottom:6px">'
              + '<i class="bi bi-heart-fill" style="color:#10b981;font-size:0.75rem;flex-shrink:0"></i>'
              + '<div>'
              + '<div style="font-size:0.85rem;font-weight:600;color:#f1f5f9">' + p.nome + '</div>'
              + '<div style="font-size:0.75rem;color:#6b7280;margin-top:1px">' + detalhes.join(' · ') + '</div>'
              + '</div>'
              + '</div>';
          }).join('');
        });
    }

    function salvarEdicao() {
      var nome = document.getElementById('edit-nome').value.trim();
      var telefone = document.getElementById('edit-telefone').value.trim();
      var email = document.getElementById('edit-email').value.trim();
      var telPattern = /^\(\d{2}\) \d{5}-\d{4}$/;
      var emailPattern = /^[^\s@]+@[^\s@]+\.(com|com\.br|net|org)$/;

      document.getElementById('edit-erro').classList.add('d-none');

      if (!nome) return mostrarErroEdit('Informe o nome do cliente.');
      if (!telefone) return mostrarErroEdit('Informe o telefone do cliente.');
      if (!telPattern.test(telefone)) return mostrarErroEdit('Telefone inválido. Use o formato (XX) XXXXX-XXXX.');
      if (!email) return mostrarErroEdit('Informe o e-mail do cliente.');
      if (!emailPattern.test(email)) return mostrarErroEdit('E-mail inválido. Use um e-mail terminado em .com, .com.br, .net ou .org.');

      fetch('/clientes/' + clienteEditandoId, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nome: nome, telefone: telefone, email: email })
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) {
          location.href = '/clientes?sucesso=editado';
        } else if (data.erro === 'telefone_duplicado') {
          mostrarErroEdit('Esse telefone já está cadastrado para outro cliente.');
        } else if (data.erro === 'email_duplicado') {
          mostrarErroEdit('Esse e-mail já está cadastrado para outro cliente.');
        } else {
          mostrarErroEdit('Erro ao salvar. Tente novamente.');
        }
      });
    }

    function excluir(url) {
      _urlExcluir = url;
      _modalConfirmar = new bootstrap.Modal(document.getElementById('modalConfirmar'));
      _modalConfirmar.show();
    }

    document.getElementById('btnConfirmarExcluir').addEventListener('click', function() {
      if (_urlExcluir) {
        fetch(_urlExcluir, { method: 'DELETE' }).then(function() {
          _modalConfirmar.hide();
          location.reload();
        });
      }
    });
  </script>

</body>
</html>

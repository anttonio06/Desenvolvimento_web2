<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clientes - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-people-fill"></i> Clientes</div>
        <div class="page-subtitle">Gerencie os clientes do pet shop</div>
      </div>
      <button class="btn-primary-action">
        <i class="bi bi-plus-lg"></i> Novo Cliente
      </button>
    </div>

    <div class="section-card">
      <div class="search-bar">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar cliente por nome, email ou telefone..." id="busca-cliente">
      </div>

      <table class="table-agendamentos" id="tabela-clientes">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Pets</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (clientes.length === 0) { %>
            <tr>
              <td colspan="6">
                <div class="empty-state">
                  <i class="bi bi-people"></i>
                  Nenhum cliente cadastrado ainda.
                </div>
              </td>
            </tr>
          <% } else { %>
            <% clientes.forEach(function(c) { %>
              <tr>
                <td><%= c.id %></td>
                <td><strong><%= c.nome %></strong></td>
                <td><%= c.telefone %></td>
                <td><%= c.email %></td>
                <td><span class="badge-status badge-confirmado"><%= c.total_pets || 0 %> pet(s)</span></td>
                <td class="acoes">
                  <a href="/clientes/<%= c.id %>" class="btn-acao editar" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                  <button class="btn-acao excluir" title="Excluir" onclick="excluir('/clientes/<%= c.id %>')"><i class="bi bi-trash-fill"></i></button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

  </main>

  <script>
    document.getElementById('busca-cliente').addEventListener('input', function() {
      var termo = this.value.toLowerCase();
      document.querySelectorAll('#tabela-clientes tbody tr').forEach(function(tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    });

    function excluir(url) {
      if (confirm('Deseja excluir este cliente?')) {
        fetch(url, { method: 'DELETE' }).then(function() { location.reload(); });
      }
    }
  </script>

</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Clientes - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-people-fill"></i> Clientes</div>
        <div class="page-subtitle">Gerencie os clientes do pet shop</div>
      </div>
      <button class="btn-primary-action" data-bs-toggle="modal" data-bs-target="#modalNovoCliente">
        <i class="bi bi-plus-lg"></i> Novo Cliente
      </button>
    </div>

    <div class="section-card">
      <div class="search-bar">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar cliente por nome, email ou telefone..." id="busca-cliente">
      </div>

      <table class="table-agendamentos" id="tabela-clientes">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome</th>
            <th>Telefone</th>
            <th>Email</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (clientes.length === 0) { %>
            <tr>
              <td colspan="5">
                <div class="empty-state">
                  <i class="bi bi-people"></i>
                  Nenhum cliente cadastrado ainda.
                </div>
              </td>
            </tr>
          <% } else { %>
            <% clientes.forEach(function(c) { %>
              <tr>
                <td><%= c.id %></td>
                <td><strong><%= c.nome %></strong></td>
                <td><%= c.telefone || '-' %></td>
                <td><%= c.email || '-' %></td>
                <td class="acoes">
                  <button class="btn-acao excluir" title="Excluir" onclick="excluir('/clientes/<%= c.id %>')"><i class="bi bi-trash-fill"></i></button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

  </main>

  <!-- Modal Novo Cliente -->
  <div class="modal fade" id="modalNovoCliente" tabindex="-1" aria-labelledby="modalNovoClienteLabel" aria-hidden="true">
    <div class="modal-dialog">
      <form method="POST" action="/clientes">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="modalNovoClienteLabel"><i class="bi bi-person-plus-fill me-2"></i>Novo Cliente</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
          </div>
          <div class="modal-body">
            <div class="mb-3">
              <label class="form-label fw-semibold">Nome <span class="text-danger">*</span></label>
              <input type="text" name="nome" class="form-control" placeholder="Nome completo" required>
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">Telefone</label>
              <input type="text" name="telefone" class="form-control" placeholder="(00) 00000-0000">
            </div>
            <div class="mb-3">
              <label class="form-label fw-semibold">E-mail</label>
              <input type="email" name="email" class="form-control" placeholder="email@exemplo.com">
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
            <button type="submit" class="btn btn-success">Cadastrar</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('busca-cliente').addEventListener('input', function() {
      var termo = this.value.toLowerCase();
      document.querySelectorAll('#tabela-clientes tbody tr').forEach(function(tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    });

    function excluir(url) {
      if (confirm('Deseja excluir este cliente?')) {
        fetch(url, { method: 'DELETE' }).then(function() { location.reload(); });
      }
    }
  </script>

</body>
</html>

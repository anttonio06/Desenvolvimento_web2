<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/login.css">

  <style>
    .forgot-card {
      width: 100%;
      max-width: 420px;
      background: #111827;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 24px 64px rgba(0,0,0,0.6);
      padding: 44px 40px 34px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .back-link {
      position: absolute;
      top: 14px;
      left: 16px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: #4b5563;
      font-size: 0.78rem;
      font-weight: 500;
      text-decoration: none;
      padding: 5px 10px;
      border-radius: 7px;
      transition: color 0.15s;
    }
    .back-link:hover { color: #9ca3af; }

    .forgot-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: #f9fafb;
      letter-spacing: -0.03em;
      margin-bottom: 0;
    }

    .forgot-subtitle {
      color: #374151;
      font-size: 0.8rem;
      line-height: 1.65;
      margin-bottom: 0;
    }

    .custom-input {
      height: 46px !important;
    }

    .divider {
      height: 1px;
      background: rgba(255,255,255,0.05);
      margin: 20px 0 12px;
    }
  </style>
</head>
<body>
  <main class="login-page d-flex align-items-center justify-content-center">
    <div class="forgot-card" style="position:relative;">

      <a href="/login" class="back-link">
        <i class="bi bi-arrow-left"></i> Voltar
      </a>

      <div class="brand mb-4" style="justify-content:center; font-size:2.6em; gap:12px;">
        <svg class="brand-icon" width="38" height="28" viewBox="0 0 130 100" fill="#10b981" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="16" cy="38" rx="6" ry="8"/>
          <ellipse cx="27" cy="32" rx="6" ry="8"/>
          <ellipse cx="38" cy="32" rx="6" ry="8"/>
          <ellipse cx="49" cy="38" rx="6" ry="8"/>
          <path d="M32 48 C17 48 9 59 13 70 C16 79 24 85 32 85 C40 85 48 79 51 70 C55 59 47 48 32 48Z"/>
          <ellipse cx="80" cy="12" rx="5.5" ry="7.5"/>
          <ellipse cx="91" cy="6" rx="5.5" ry="7.5"/>
          <ellipse cx="102" cy="6" rx="5.5" ry="7.5"/>
          <ellipse cx="113" cy="12" rx="5.5" ry="7.5"/>
          <path d="M96 22 C82 22 74 33 78 43 C81 52 89 57 96 57 C103 57 111 52 114 43 C118 33 110 22 96 22Z"/>
        </svg>
        <span class="brand-text" style="font-size:1.3rem;">PetAgenda</span>
      </div>

      <h1 class="forgot-title" style="text-align:center;">Esqueceu a senha?</h1>
      <p class="forgot-subtitle" style="text-align:center; margin-top:8px; margin-bottom:22px;">
        Digite seu e-mail e enviaremos um link para definir uma nova senha.
      </p>

      <% if (erro) { %>
        <div class="alert alert-danger py-2 mb-3"><%= erro %></div>
      <% } %>

      <% if (sucesso) { %>
        <div class="alert alert-success py-2 mb-3"><%= sucesso %></div>
      <% } %>

      <div id="erro-email-vazio" class="alert alert-danger py-2 mb-3" style="display:none">Informe o e-mail.</div>

      <form action="/esqueci-senha" method="POST" id="form-esqueci">
        <div class="mb-3">
          <label for="email" class="form-label">Email:</label>
          <input
            type="email"
            class="form-control custom-input"
            id="email"
            name="email"
            placeholder="seu@email.com"
          >
        </div>

        <button type="submit" class="btn login-btn w-100">
          Enviar link de recuperação
        </button>
      </form>

      <script>
        document.getElementById('form-esqueci').addEventListener('submit', function(e) {
          var email = document.getElementById('email').value.trim();
          if (!email) {
            e.preventDefault();
            document.getElementById('erro-email-vazio').style.display = '';
          }
        });
      </script>


    </div>
  </main>
</body>
</html>

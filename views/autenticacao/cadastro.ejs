<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <main class="login-page d-flex align-items-center justify-content-center">
    <div class="register-card shadow-lg">
      <div class="register-wrapper">
        <div class="brand mb-4">
          <svg class="brand-icon" width="24" height="18" viewBox="0 0 130 100" fill="#10b981" xmlns="http://www.w3.org/2000/svg">
            <ellipse cx="16" cy="38" rx="6" ry="8"/>
            <ellipse cx="27" cy="32" rx="6" ry="8"/>
            <ellipse cx="38" cy="32" rx="6" ry="8"/>
            <ellipse cx="49" cy="38" rx="6" ry="8"/>
            <path d="M32 48 C17 48 9 59 13 70 C16 79 24 85 32 85 C40 85 48 79 51 70 C55 59 47 48 32 48Z"/>
            <ellipse cx="80" cy="12" rx="5.5" ry="7.5"/>
            <ellipse cx="91" cy="6" rx="5.5" ry="7.5"/>
            <ellipse cx="102" cy="6" rx="5.5" ry="7.5"/>
            <ellipse cx="113" cy="12" rx="5.5" ry="7.5"/>
            <path d="M96 22 C82 22 74 33 78 43 C81 52 89 57 96 57 C103 57 111 52 114 43 C118 33 110 22 96 22Z"/>
          </svg>
          <span class="brand-text">PetAgenda</span>
        </div>

        <h1 class="register-title">Cadastre-se</h1>
        <p class="login-subtitle">Informe seus dados:</p>

        <% if (erro) { %>
          <div class="alert alert-danger py-2"><%= erro %></div>
        <% } %>

        <% if (sucesso) { %>
          <div class="alert alert-success py-2"><%= sucesso %></div>
        <% } %>

        <form action="/cadastro" method="POST" class="mt-3" id="form-cadastro" novalidate>
          <div id="erro-campos" class="alert alert-danger py-2 d-none"></div>

          <div class="mb-3">
            <label for="nome" class="form-label">Nome completo:</label>
            <input type="text" class="form-control custom-input" id="nome" name="nome" value="<%= dados?.nome || '' %>">
          </div>

          <div class="mb-3">
            <label for="email" class="form-label">Email:</label>
            <input type="text" class="form-control custom-input" id="email" name="email" value="<%= dados?.email || '' %>">
          </div>

          <div class="mb-3">
            <label for="telefone" class="form-label">Telefone:</label>
            <input type="text" class="form-control custom-input" id="telefone" name="telefone" value="<%= dados?.telefone || '' %>">
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <label for="senha" class="form-label">Senha:</label>
              <input type="password" class="form-control custom-input" id="senha" name="senha">
            </div>
            <div class="col-md-6 mb-3">
              <label for="confirmarSenha" class="form-label">Confirmar senha:</label>
              <input type="password" class="form-control custom-input" id="confirmarSenha" name="confirmarSenha">
            </div>
          </div>

          <button type="submit" class="btn login-btn w-100 mt-2">Cadastrar</button>

          <div class="mt-3 text-center">
            <a href="/login" class="small-link">Já tenho cadastro</a>
          </div>
        </form>
      </div>
    </div>
  </main>

  <script>
    document.getElementById('form-cadastro').addEventListener('submit', function(e) {
      var nome          = document.getElementById('nome').value.trim();
      var email         = document.getElementById('email').value.trim();
      var telefone      = document.getElementById('telefone').value.trim();
      var senha         = document.getElementById('senha').value;
      var confirmar     = document.getElementById('confirmarSenha').value;
      var erroEl        = document.getElementById('erro-campos');

      erroEl.classList.add('d-none');

      if (!nome || !email || !telefone || !senha || !confirmar) {
        e.preventDefault();
        erroEl.textContent = 'Preencha todos os campos antes de continuar.';
        erroEl.classList.remove('d-none');
        return;
      }

      if (senha !== confirmar) {
        e.preventDefault();
        erroEl.textContent = 'As senhas não coincidem.';
        erroEl.classList.remove('d-none');
      }
    });
  </script>
</body>
</html>
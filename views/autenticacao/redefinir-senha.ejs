<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/login.css">
  <style>
    .forgot-card {
      width: 100%;
      max-width: 420px;
      background: #111827;
      border-radius: 16px;
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 24px 64px rgba(0,0,0,0.6);
      padding: 44px 40px 34px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .back-link {
      position: absolute;
      top: 14px;
      left: 16px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
      color: #4b5563;
      font-size: 0.78rem;
      font-weight: 500;
      text-decoration: none;
      padding: 5px 10px;
      border-radius: 7px;
      transition: color 0.15s;
    }
    .back-link:hover { color: #9ca3af; }
    .forgot-title {
      font-size: 1.4rem;
      font-weight: 700;
      color: #f9fafb;
      letter-spacing: -0.03em;
      margin-bottom: 0;
    }
    .forgot-subtitle {
      color: #374151;
      font-size: 0.8rem;
      line-height: 1.65;
      margin-bottom: 0;
    }
    .custom-input { height: 46px !important; }
    .divider {
      height: 1px;
      background: rgba(255,255,255,0.05);
      margin: 20px 0 12px;
    }
  </style>
</head>
<body>
  <main class="login-page d-flex align-items-center justify-content-center">
    <div class="forgot-card" style="position:relative;">

      <a href="/login" class="back-link">
        <i class="bi bi-arrow-left"></i> Voltar ao login
      </a>

      <div class="brand mb-4" style="justify-content:center; font-size:2.6em; gap:12px;">
        <svg class="brand-icon" width="38" height="28" viewBox="0 0 130 100" fill="#10b981" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="16" cy="38" rx="6" ry="8"/>
          <ellipse cx="27" cy="32" rx="6" ry="8"/>
          <ellipse cx="38" cy="32" rx="6" ry="8"/>
          <ellipse cx="49" cy="38" rx="6" ry="8"/>
          <path d="M32 48 C17 48 9 59 13 70 C16 79 24 85 32 85 C40 85 48 79 51 70 C55 59 47 48 32 48Z"/>
          <ellipse cx="80" cy="12" rx="5.5" ry="7.5"/>
          <ellipse cx="91" cy="6" rx="5.5" ry="7.5"/>
          <ellipse cx="102" cy="6" rx="5.5" ry="7.5"/>
          <ellipse cx="113" cy="12" rx="5.5" ry="7.5"/>
          <path d="M96 22 C82 22 74 33 78 43 C81 52 89 57 96 57 C103 57 111 52 114 43 C118 33 110 22 96 22Z"/>
        </svg>
        <span class="brand-text" style="font-size:1.3rem;">PetAgenda</span>
      </div>

      <% if (sucesso) { %>
        <div class="text-center mb-3">
          <i class="bi bi-check-circle-fill" style="font-size:2.5rem;color:#10b981;display:block;margin-bottom:12px"></i>
          <h1 class="forgot-title">Senha redefinida!</h1>
          <p style="color:#6b7280;font-size:0.85rem;margin-top:10px;"><%= sucesso %></p>
        </div>
        <a href="/login" class="btn login-btn w-100">Ir para o login</a>
      <% } else if (!token) { %>
        <div class="text-center mb-3">
          <i class="bi bi-x-circle-fill" style="font-size:2.5rem;color:#f87171;display:block;margin-bottom:12px"></i>
          <h1 class="forgot-title">Link inválido</h1>
          <p style="color:#6b7280;font-size:0.85rem;margin-top:10px;"><%= erro %></p>
        </div>
        <a href="/esqueci-senha" class="btn login-btn w-100">Solicitar novo link</a>
      <% } else { %>
        <h1 class="forgot-title" style="text-align:center;">Nova senha</h1>
        <p class="forgot-subtitle" style="text-align:center; margin-top:8px; margin-bottom:22px;">
          Escolha uma nova senha para sua conta.
        </p>

        <% if (erro) { %>
          <div class="alert alert-danger py-2 mb-3"><%= erro %></div>
        <% } %>

        <form action="/redefinir-senha/<%= token %>" method="POST">
          <div class="mb-3">
            <label for="nova_senha" class="form-label">Nova senha</label>
            <input type="password" class="form-control custom-input" id="nova_senha" name="nova_senha"
              placeholder="Mínimo 6 caracteres" required minlength="6">
          </div>
          <div class="mb-3">
            <label for="confirmar_senha" class="form-label">Confirmar nova senha</label>
            <input type="password" class="form-control custom-input" id="confirmar_senha" name="confirmar_senha"
              placeholder="Repita a senha" required minlength="6">
          </div>
          <button type="submit" class="btn login-btn w-100">Redefinir senha</button>
        </form>
      <% } %>

    </div>
  </main>
</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
  <link rel="stylesheet" href="/css/login.css">
</head>
<body>
  <main class="login-page d-flex align-items-center justify-content-center">
    <div class="login-card shadow-lg">
      <div class="row g-0 h-100">
        
        <div class="col-lg-7 col-md-7 col-12 form-side">
          <div class="form-wrapper">
            <div class="brand mb-4">
              <svg class="brand-icon" width="24" height="18" viewBox="0 0 130 100" fill="#10b981" xmlns="http://www.w3.org/2000/svg">
                <ellipse cx="16" cy="38" rx="6" ry="8"/>
                <ellipse cx="27" cy="32" rx="6" ry="8"/>
                <ellipse cx="38" cy="32" rx="6" ry="8"/>
                <ellipse cx="49" cy="38" rx="6" ry="8"/>
                <path d="M32 48 C17 48 9 59 13 70 C16 79 24 85 32 85 C40 85 48 79 51 70 C55 59 47 48 32 48Z"/>
                <ellipse cx="80" cy="12" rx="5.5" ry="7.5"/>
                <ellipse cx="91" cy="6" rx="5.5" ry="7.5"/>
                <ellipse cx="102" cy="6" rx="5.5" ry="7.5"/>
                <ellipse cx="113" cy="12" rx="5.5" ry="7.5"/>
                <path d="M96 22 C82 22 74 33 78 43 C81 52 89 57 96 57 C103 57 111 52 114 43 C118 33 110 22 96 22Z"/>
              </svg>
              <span class="brand-text">PetAgenda</span>
            </div>

            <h1 class="login-title">Bem-vindo ao PetAgenda</h1>
            <p class="login-subtitle">
              Organize os agendamentos do seu pet shop de forma fácil e eficiente.
            </p>

            <% if (erro) { %>
              <div class="alert alert-danger py-2"><%= erro %></div>
            <% } %>

            <% if (sucesso) { %>
              <div class="alert alert-success py-2"><%= sucesso %></div>
            <% } %>

            <form action="/login" method="POST" class="mt-4">
              <div class="mb-3">
                <label for="email" class="form-label">Email:</label>
                <input
                  type="email"
                  class="form-control custom-input"
                  id="email"
                  name="email"
                  placeholder="seu@email.com"
                  required
                >
              </div>

              <div class="mb-3">
                <label for="senha" class="form-label">Senha:</label>
                <input
                  type="password"
                  class="form-control custom-input"
                  id="senha"
                  name="senha"
                  placeholder="••••••"
                  required
                >
              </div>

              <button type="submit" class="btn login-btn w-100">
                Entrar
              </button>

              <div class="bottom-links mt-3">
                <a href="/esqueci-senha" class="small-link">Esqueceu a senha?</a>
              </div>
            </form>
          </div>
        </div>

        <div class="col-lg-5 col-md-5 d-none d-md-flex illustration-side">
          <div class="illustration-content">
            <h2 class="illustration-title">PetAgenda</h2>
            <p class="illustration-desc">Organize agendamentos, clientes e pets do seu pet shop em um só lugar.</p>
            <div class="illustration-features">
              <div class="feat-item"><i class="bi bi-calendar2-check"></i> Agendamentos simples</div>
              <div class="feat-item"><i class="bi bi-people"></i> Gestão de clientes</div>
              <div class="feat-item"><i class="bi bi-heart"></i> Cadastro de pets</div>
              <div class="feat-item"><i class="bi bi-scissors"></i> Controle de serviços</div>
            </div>
          </div>
        </div>
        </div>

      </div>
    </div>
  </main>

</body>
</html>
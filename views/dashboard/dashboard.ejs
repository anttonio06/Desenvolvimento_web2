<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - PetAgenda</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <!-- ── Main Content ── -->
  <main class="main-content">

    <!-- Header -->
    <div class="dash-header">
      <div>
        <div class="dash-greeting">Olá, <%= usuario.nome.split(' ')[0] %>! 👋</div>
        <div class="dash-subtitle">Aqui está o resumo do pet shop hoje.</div>
      </div>
      <div class="dash-date-badge">
        <i class="bi bi-calendar3 me-1"></i>
        <%= new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }) %>
      </div>
    </div>

    <!-- Cards de resumo -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-people-fill"></i></div>
        <div>
          <div class="stat-value">48</div>
          <div class="stat-label">Clientes cadastrados</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon blue"><i class="bi bi-heart-fill"></i></div>
        <div>
          <div class="stat-value">63</div>
          <div class="stat-label">Pets cadastrados</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon orange"><i class="bi bi-calendar2-check-fill"></i></div>
        <div>
          <div class="stat-value">7</div>
          <div class="stat-label">Agendamentos hoje</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple"><i class="bi bi-scissors"></i></div>
        <div>
          <div class="stat-value">5</div>
          <div class="stat-label">Serviços disponíveis</div>
        </div>
      </div>
    </div>

    <!-- Agendamentos do Dia -->
    <div class="section-card">
      <div class="section-title">
        <i class="bi bi-calendar2-day-fill"></i> Agendamentos de Hoje
      </div>
      <table class="table-agendamentos">
        <thead>
          <tr>
            <th>Horário</th>
            <th>Cliente</th>
            <th>Pet</th>
            <th>Serviço</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td><strong>08:30</strong></td>
            <td>Ana Paula Silva</td>
            <td>🐶 Thor (Golden Retriever)</td>
            <td>Banho e Tosa</td>
            <td><span class="badge-status badge-confirmado">Confirmado</span></td>
          </tr>
          <tr>
            <td><strong>09:15</strong></td>
            <td>Carlos Mendes</td>
            <td>🐱 Mingau (Persa)</td>
            <td>Banho</td>
            <td><span class="badge-status badge-concluido">Concluído</span></td>
          </tr>
          <tr>
            <td><strong>10:00</strong></td>
            <td>Fernanda Costa</td>
            <td>🐶 Mel (Poodle)</td>
            <td>Tosa Higiênica</td>
            <td><span class="badge-status badge-confirmado">Confirmado</span></td>
          </tr>
          <tr>
            <td><strong>11:30</strong></td>
            <td>Roberto Alves</td>
            <td>🐶 Bolinha (Shih Tzu)</td>
            <td>Banho e Tosa</td>
            <td><span class="badge-status badge-pendente">Pendente</span></td>
          </tr>
          <tr>
            <td><strong>13:00</strong></td>
            <td>Juliana Rocha</td>
            <td>🐱 Luna (Siamês)</td>
            <td>Banho</td>
            <td><span class="badge-status badge-confirmado">Confirmado</span></td>
          </tr>
          <tr>
            <td><strong>14:30</strong></td>
            <td>Marcos Lima</td>
            <td>🐶 Rex (Labrador)</td>
            <td>Consulta Veterinária</td>
            <td><span class="badge-status badge-cancelado">Cancelado</span></td>
          </tr>
          <tr>
            <td><strong>16:00</strong></td>
            <td>Patricia Souza</td>
            <td>🐶 Pipoca (Lulu da Pomerânia)</td>
            <td>Banho e Tosa</td>
            <td><span class="badge-status badge-pendente">Pendente</span></td>
          </tr>
        </tbody>
      </table>
    </div>

    <!-- Resumo Semanal + Pets por espécie -->
    <div class="two-col-grid">

      <!-- Resumo Semanal -->
      <div class="section-card" style="margin-bottom:0">
        <div class="section-title">
          <i class="bi bi-bar-chart-fill"></i> Resumo Semanal
        </div>

        <div class="bar-item">
          <div class="bar-label"><span>Segunda-feira</span><span>8 agendamentos</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:80%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>Terça-feira</span><span>6 agendamentos</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:60%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>Quarta-feira</span><span>10 agendamentos</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:100%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>Quinta-feira</span><span>5 agendamentos</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:50%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>Sexta-feira</span><span>9 agendamentos</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:90%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>Sábado</span><span>7 agendamentos</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:70%"></div></div>
        </div>
      </div>

      <!-- Pets por espécie -->
      <div class="section-card" style="margin-bottom:0">
        <div class="section-title">
          <i class="bi bi-pie-chart-fill"></i> Pets por Espécie
        </div>

        <div class="bar-item">
          <div class="bar-label"><span>🐶 Cães</span><span>41 pets (65%)</span></div>
          <div class="bar-track"><div class="bar-fill" style="width:65%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>🐱 Gatos</span><span>16 pets (25%)</span></div>
          <div class="bar-track"><div class="bar-fill blue" style="width:25%"></div></div>
        </div>
        <div class="bar-item">
          <div class="bar-label"><span>🐰 Outros</span><span>6 pets (10%)</span></div>
          <div class="bar-track"><div class="bar-fill purple" style="width:10%"></div></div>
        </div>

        <hr style="border-color:#f0f0f0; margin: 20px 0 16px">

        <div class="section-title" style="margin-bottom:12px">
          <i class="bi bi-person-lines-fill"></i> Últimos Clientes
        </div>
        <div style="display:flex; flex-direction:column; gap:10px">
          <div style="display:flex; justify-content:space-between; align-items:center; font-size:0.88rem">
            <span style="color:#1f2937; font-weight:500">Ana Paula Silva</span>
            <span style="color:#9ca3af">2 pets · cadastrado há 3 dias</span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; font-size:0.88rem">
            <span style="color:#1f2937; font-weight:500">Carlos Mendes</span>
            <span style="color:#9ca3af">1 pet · cadastrado há 1 semana</span>
          </div>
          <div style="display:flex; justify-content:space-between; align-items:center; font-size:0.88rem">
            <span style="color:#1f2937; font-weight:500">Fernanda Costa</span>
            <span style="color:#9ca3af">1 pet · cadastrado há 2 semanas</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Espaço entre grids -->
    <div style="height: 20px"></div>

    <!-- Resumo Mensal + Serviços -->
    <div class="two-col-grid">

      <!-- Resumo Mensal -->
      <div class="section-card" style="margin-bottom:0">
        <div class="section-title">
          <i class="bi bi-graph-up-arrow"></i> Resumo Mensal (últimos 6 meses)
        </div>

        <div class="monthly-bars" id="monthly-bars">
          <div class="monthly-bar-wrap" data-mes="Outubro" data-agend="52" data-fat="3.744" data-clientes="9">
            <div class="monthly-bar-value">52</div>
            <div class="monthly-bar" style="height:52px"></div>
            <div class="monthly-bar-label">Out</div>
          </div>
          <div class="monthly-bar-wrap" data-mes="Novembro" data-agend="67" data-fat="4.824" data-clientes="11">
            <div class="monthly-bar-value">67</div>
            <div class="monthly-bar" style="height:67px"></div>
            <div class="monthly-bar-label">Nov</div>
          </div>
          <div class="monthly-bar-wrap" data-mes="Dezembro" data-agend="80" data-fat="5.760" data-clientes="15">
            <div class="monthly-bar-value">80</div>
            <div class="monthly-bar" style="height:80px"></div>
            <div class="monthly-bar-label">Dez</div>
          </div>
          <div class="monthly-bar-wrap" data-mes="Janeiro" data-agend="61" data-fat="4.392" data-clientes="10">
            <div class="monthly-bar-value">61</div>
            <div class="monthly-bar" style="height:61px"></div>
            <div class="monthly-bar-label">Jan</div>
          </div>
          <div class="monthly-bar-wrap" data-mes="Fevereiro" data-agend="74" data-fat="5.328" data-clientes="13">
            <div class="monthly-bar-value">74</div>
            <div class="monthly-bar" style="height:74px"></div>
            <div class="monthly-bar-label">Fev</div>
          </div>
          <div class="monthly-bar-wrap selected" data-mes="Março" data-agend="45" data-fat="3.240" data-clientes="12">
            <div class="monthly-bar-value">45</div>
            <div class="monthly-bar current" style="height:45px"></div>
            <div class="monthly-bar-label">Mar</div>
          </div>
        </div>

        <hr style="border-color:#f0f0f0; margin: 20px 0 14px">

        <div style="font-size:0.82rem; color:#9ca3af; text-align:center; margin-bottom:10px" id="mes-selecionado">
          <i class="bi bi-cursor-fill"></i> Março (mês atual)
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px; text-align:center">
          <div>
            <div style="font-size:1.3rem; font-weight:700; color:#198f73" id="stat-agend">45</div>
            <div style="font-size:0.78rem; color:#9ca3af">Agendamentos</div>
          </div>
          <div>
            <div style="font-size:1.3rem; font-weight:700; color:#2563eb" id="stat-fat">R$ 3.240</div>
            <div style="font-size:0.78rem; color:#9ca3af">Faturamento</div>
          </div>
          <div>
            <div style="font-size:1.3rem; font-weight:700; color:#ea580c" id="stat-clientes">12</div>
            <div style="font-size:0.78rem; color:#9ca3af">Novos clientes</div>
          </div>
        </div>
      </div>

      <!-- Serviços -->
      <div class="section-card" style="margin-bottom:0">
        <div class="section-title">
          <i class="bi bi-scissors"></i> Serviços
        </div>

        <div class="service-item">
          <div>
            <div class="service-name">Banho e Tosa</div>
            <div class="service-meta">Duração: 90 min · Mais solicitado</div>
          </div>
          <div class="service-price">R$ 80,00</div>
        </div>
        <div class="service-item">
          <div>
            <div class="service-name">Banho</div>
            <div class="service-meta">Duração: 60 min</div>
          </div>
          <div class="service-price">R$ 50,00</div>
        </div>
        <div class="service-item">
          <div>
            <div class="service-name">Tosa Higiênica</div>
            <div class="service-meta">Duração: 45 min</div>
          </div>
          <div class="service-price">R$ 40,00</div>
        </div>
        <div class="service-item">
          <div>
            <div class="service-name">Consulta Veterinária</div>
            <div class="service-meta">Duração: 30 min</div>
          </div>
          <div class="service-price">R$ 120,00</div>
        </div>
        <div class="service-item">
          <div>
            <div class="service-name">Hidratação</div>
            <div class="service-meta">Duração: 40 min</div>
          </div>
          <div class="service-price">R$ 35,00</div>
        </div>
      </div>

    </div>

    <div style="height: 32px"></div>

  </main>

<script>
  document.querySelectorAll('.monthly-bar-wrap').forEach(function(wrap) {
    wrap.addEventListener('click', function() {
      document.querySelectorAll('.monthly-bar-wrap').forEach(function(el) {
        el.classList.remove('selected');
      });

      wrap.classList.add('selected');

      var mes      = wrap.dataset.mes;
      var agend    = wrap.dataset.agend;
      var fat      = wrap.dataset.fat;
      var clientes = wrap.dataset.clientes;

      document.getElementById('stat-agend').textContent    = agend;
      document.getElementById('stat-fat').textContent      = 'R$ ' + fat;
      document.getElementById('stat-clientes').textContent = clientes;
      document.getElementById('mes-selecionado').innerHTML =
        '<i class="bi bi-cursor-fill"></i> ' + mes;
    });
  });
</script>

</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - PetAgenda</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <!-- ── Main Content ── -->
  <main class="main-content">

    <!-- Header -->
    <div class="dash-header">
      <div>
        <div class="dash-greeting">Olá, <%= usuario.nome.split(' ')[0] %>!</div>
        <div class="dash-subtitle">Aqui está o resumo do pet shop hoje.</div>
      </div>
      <div class="dash-date-badge">
        <i class="bi bi-calendar3 me-1"></i>
        <%= new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }) %>
      </div>
    </div>

    <!-- Cards de resumo -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-people-fill"></i></div>
        <div>
          <div class="stat-value"><%= totalClientes %></div>
          <div class="stat-label">Clientes cadastrados</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon blue"><i class="bi bi-heart-fill"></i></div>
        <div>
          <div class="stat-value"><%= totalPets %></div>
          <div class="stat-label">Pets cadastrados</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon orange"><i class="bi bi-calendar2-check-fill"></i></div>
        <div>
          <div class="stat-value"><%= totalHoje %></div>
          <div class="stat-label">Agendamentos hoje</div>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon purple"><i class="bi bi-scissors"></i></div>
        <div>
          <div class="stat-value"><%= totalServicos %></div>
          <div class="stat-label">Serviços disponíveis</div>
        </div>
      </div>
    </div>

    <!-- Últimos Clientes + Pets por espécie -->
    <div class="two-col-grid">

      <!-- Últimos Clientes -->
      <div class="section-card" style="margin-bottom:0">
        <div class="section-title">
          <i class="bi bi-person-lines-fill"></i> Clientes Cadastrados
        </div>

        <% if (ultimosClientes.length === 0) { %>
          <div class="empty-state" style="padding: 24px 0">
            <i class="bi bi-people"></i>
            Nenhum cliente cadastrado ainda.
          </div>
        <% } else { %>
          <div class="scroll-list" style="display:flex; flex-direction:column; gap:10px; margin-top:12px">
            <% ultimosClientes.forEach(function(c) { %>
              <div style="display:flex; justify-content:space-between; align-items:center; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.04)">
                <span class="nome-destaque"><%= c.nome %></span>
                <span style="font-size:0.72rem; color:#94a3b8">
                  <%= new Date(c.criado_em.replace(' ', 'T') + 'Z').toLocaleDateString('pt-BR', { timeZone: 'America/Sao_Paulo' }) %>
                </span>
              </div>
            <% }) %>
          </div>
          <div style="margin-top:14px">
            <a href="/clientes" style="font-size:0.82rem; color:#6b9bf5; text-decoration:none">Ver todos os clientes &rarr;</a>
          </div>
        <% } %>
      </div>

      <!-- Agendamentos -->
      <div class="section-card" style="margin-bottom:0">
        <div class="section-title">
          <i class="bi bi-calendar2-week-fill"></i> Agendamentos
        </div>

        <% if (agendamentos.length === 0) { %>
          <div class="empty-state" style="padding: 24px 0">
            <i class="bi bi-calendar2-x"></i>
            Nenhum agendamento cadastrado ainda.
          </div>
        <% } else { %>
          <div class="scroll-list" style="display:flex; flex-direction:column; gap:8px; margin-top:12px">
            <% agendamentos.forEach(function(a) { %>
              <div style="display:flex; justify-content:space-between; align-items:center; padding: 9px 0; border-bottom: 1px solid rgba(255,255,255,0.04)">
                <div style="display:flex; flex-direction:column; gap:2px">
                  <span class="nome-destaque"><%= a.pet_nome || '—' %></span>
                  <span style="font-size:0.72rem; color:#64748b"><%= a.servico_nome || '—' %></span>
                  <span style="font-size:0.7rem; color:#475569">
                    <%= new Date(a.data_hora).toLocaleDateString('pt-BR') %>
                    &bull;
                    <%= new Date(a.data_hora).toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'}) %>
                  </span>
                </div>
                <% if (a.status === 'confirmado') { %>
                  <span class="badge-status badge-confirmado">Confirmado</span>
                <% } else if (a.status === 'pendente') { %>
                  <span class="badge-status badge-pendente">Pendente</span>
                <% } else if (a.status === 'concluido') { %>
                  <span class="badge-status badge-concluido">Concluído</span>
                <% } else { %>
                  <span class="badge-status badge-cancelado">Cancelado</span>
                <% } %>
              </div>
            <% }) %>
          </div>
          <div style="margin-top:14px">
            <a href="/agendamentos" style="font-size:0.82rem; color:#6b9bf5; text-decoration:none">Ver todos os agendamentos &rarr;</a>
          </div>
        <% } %>
      </div>

    </div>

    <div style="height: 32px"></div>

  </main>

</body>
</html>

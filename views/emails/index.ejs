<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuários - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-people-fill"></i> Usuários do Sistema</div>
        <div class="page-subtitle">Gerencie os usuários cadastrados</div>
      </div>
    </div>

    <div class="section-card">
      <div class="search-bar">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar por nome ou e-mail..." id="busca-usuario">
      </div>

      <table class="table-agendamentos" id="tabela-usuarios">
        <thead>
          <tr>
            <th>#</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Permissão</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (usuarios.length === 0) { %>
            <tr>
              <td colspan="5">
                <div class="empty-state">
                  <i class="bi bi-people"></i>
                  Nenhum usuário cadastrado.
                </div>
              </td>
            </tr>
          <% } else { %>
            <% usuarios.forEach(function(u, i) { %>
              <tr>
                <td><%= i + 1 %></td>
                <td><strong><%= u.nome %></strong></td>
                <td><%= u.email %></td>
                <td>
                  <% if (u.permissoes === 'administrador') { %>
                    <span style="display:inline-flex;align-items:center;gap:5px;font-size:0.78rem;font-weight:600;color:#f87171;background:rgba(239,68,68,0.1);padding:3px 10px;border-radius:20px">
                      <i class="bi bi-shield-fill" style="font-size:0.55rem"></i> Administrador
                    </span>
                  <% } else if (u.permissoes === 'funcionario') { %>
                    <span style="display:inline-flex;align-items:center;gap:5px;font-size:0.78rem;font-weight:600;color:#10b981;background:rgba(16,185,129,0.1);padding:3px 10px;border-radius:20px">
                      <i class="bi bi-person-badge-fill" style="font-size:0.55rem"></i> Funcionário
                    </span>
                  <% } else { %>
                    <span style="display:inline-flex;align-items:center;gap:5px;font-size:0.78rem;font-weight:600;color:#818cf8;background:rgba(99,102,241,0.1);padding:3px 10px;border-radius:20px">
                      <i class="bi bi-person-fill" style="font-size:0.55rem"></i> Cliente
                    </span>
                  <% } %>
                </td>
                <td class="acoes">
                  <% if (isAdmin && u.email !== 'admin@petagenda.com') { %>
                    <button class="btn-acao info" title="Ver senha" onclick="verSenha('<%= u.nome.replace(/'/g, "\\'") %>', '<%= (u.senha_texto || '').replace(/'/g, "\\'") %>')">
                      <i class="bi bi-eye-fill"></i>
                    </button>
                    <button class="btn-acao excluir" title="Excluir usuário" onclick="excluirUsuario(<%= u.id %>, '<%= u.nome.replace(/'/g, "\\'") %>')">
                      <i class="bi bi-trash-fill"></i>
                    </button>
                  <% } else { %>
                    —
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

  </main>

  <!-- Modal Ver Senha -->
  <div class="modal fade" id="modalSenha" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:400px">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-key-fill me-2"></i>Senha do usuário</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
        </div>
        <div class="modal-body">
          <div style="font-size:0.78rem;color:#64748b;margin-bottom:4px" id="modal-senha-nome"></div>
          <div style="font-family:monospace;font-size:1rem;font-weight:600;color:#f1f5f9;background:#080d14;border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:12px 14px;word-break:break-all" id="modal-senha-valor"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Fechar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Confirmar Exclusão -->
  <div class="modal fade" id="modalConfirmar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
      <div class="modal-content" style="border-radius:14px; border:1px solid rgba(239,68,68,0.2); background:#0f1624">
        <div class="modal-body p-4">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px">
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(239,68,68,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0">
              <i class="bi bi-exclamation-triangle-fill" style="color:#f87171; font-size:1.1rem"></i>
            </div>
            <h5 style="margin:0; font-size:1rem; font-weight:700; color:#f1f5f9">Confirmar exclusão</h5>
          </div>
          <p style="margin:0; font-size:0.875rem; color:#94a3b8; line-height:1.6">
            Deseja realmente excluir o usuário <strong id="modal-del-nome" style="color:#f1f5f9"></strong>? Esta ação não pode ser desfeita.
          </p>
        </div>
        <div class="modal-footer border-0 pt-0 px-4 pb-4" style="gap:10px">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="flex:1">Cancelar</button>
          <button type="button" class="btn btn-danger" id="btnConfirmarExcluir" style="flex:1">Excluir</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('busca-usuario').addEventListener('input', function() {
      var termo = this.value.toLowerCase();
      document.querySelectorAll('#tabela-usuarios tbody tr').forEach(function(tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    });

    function verSenha(nome, senha) {
      document.getElementById('modal-senha-nome').textContent = nome;
      document.getElementById('modal-senha-valor').textContent = senha || '(não disponível)';
      new bootstrap.Modal(document.getElementById('modalSenha')).show();
    }

    var _idExcluir = null;
    var _modalConfirmar = null;

    function excluirUsuario(id, nome) {
      _idExcluir = id;
      document.getElementById('modal-del-nome').textContent = nome;
      _modalConfirmar = new bootstrap.Modal(document.getElementById('modalConfirmar'));
      _modalConfirmar.show();
    }

    document.getElementById('btnConfirmarExcluir').addEventListener('click', function() {
      if (!_idExcluir) return;
      fetch('/usuarios/' + _idExcluir, { method: 'DELETE' })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.ok) { _modalConfirmar.hide(); location.reload(); }
        });
    });
  </script>

</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuários - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
  <style>
    .user-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 14px 18px;
      border-radius: 10px;
      background: #0d1421;
      border: 1px solid rgba(255,255,255,0.05);
      transition: border-color 0.15s, background 0.15s;
    }
    .user-row:hover { border-color: rgba(99,102,241,0.2); background: rgba(99,102,241,0.02); }

    .user-avatar-lg {
      width: 42px; height: 42px; border-radius: 10px;
      background: rgba(99,102,241,0.1);
      border: 1px solid rgba(99,102,241,0.18);
      display: flex; align-items: center; justify-content: center;
      color: #818cf8; font-size: 1rem; flex-shrink: 0;
    }
    .badge-perm {
      font-size: 0.63rem; font-weight: 700; padding: 3px 8px;
      border-radius: 20px; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .badge-admin { background: rgba(239,68,68,0.12); color: #f87171; }
    .badge-user  { background: rgba(99,102,241,0.12); color: #818cf8; }

    .btn-acao-sm {
      width: 32px; height: 32px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 0.82rem; border: none; cursor: pointer;
      transition: background 0.15s;
    }
    .btn-ver   { background: rgba(99,102,241,0.1); color: #818cf8; }
    .btn-ver:hover { background: rgba(99,102,241,0.22); }
    .btn-del   { background: rgba(239,68,68,0.08); color: #f87171; }
    .btn-del:hover { background: rgba(239,68,68,0.2); }

    .senha-field {
      font-family: monospace; font-size: 0.72rem; color: #64748b;
      word-break: break-all; background: #080d14;
      border: 1px solid rgba(255,255,255,0.06); border-radius: 8px;
      padding: 10px 12px; margin-top: 10px; line-height: 1.5;
    }
  </style>
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-people-fill"></i> Usuários do Sistema</div>
        <div class="page-subtitle">
          <% if (isAdmin) { %>
            Gerencie os usuários cadastrados — visão de administrador
          <% } else { %>
            Usuários cadastrados no sistema
          <% } %>
        </div>
      </div>
    </div>

    <div class="section-card">
      <div class="search-bar" style="margin-bottom:18px">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar por nome ou e-mail..." id="busca-usuario">
      </div>

      <% if (usuarios.length === 0) { %>
        <div class="empty-state">
          <i class="bi bi-people"></i>
          Nenhum usuário cadastrado.
        </div>
      <% } else { %>

        <div style="display:flex; flex-direction:column; gap:8px" id="lista-usuarios">
          <% usuarios.forEach(function(u) { %>
            <div class="user-row" data-busca="<%= (u.nome + ' ' + u.email).toLowerCase() %>">

              <div style="display:flex; align-items:center; gap:14px">
                <div class="user-avatar-lg">
                  <i class="bi bi-person-fill"></i>
                </div>
                <div>
                  <div style="display:flex; align-items:center; gap:8px; margin-bottom:3px">
                    <span style="font-size:0.9rem; font-weight:600; color:#f1f5f9"><%= u.nome %></span>
                    <% if (u.permissoes === 'administrador') { %>
                      <span class="badge-perm badge-admin">Administrador</span>
                    <% } %>
                  </div>
                  <div style="font-size:0.78rem; color:#64748b"><%= u.email %></div>
                </div>
              </div>

              <% if (isAdmin) { %>
                <div style="display:flex; gap:8px">
                  <% if (u.email !== 'admin@petagenda.com') { %>
                    <button class="btn-acao-sm btn-ver" title="Ver senha"
                      onclick="verSenha('<%= u.nome %>', '<%= u.senha_texto || '(não disponível)' %>')">
                      <i class="bi bi-eye-fill"></i>
                    </button>
                  <% } %>
                  <% if (u.email !== 'admin@petagenda.com') { %>
                    <button class="btn-acao-sm btn-del" title="Excluir usuário"
                      onclick="excluirUsuario(<%= u.id %>, '<%= u.nome %>')">
                      <i class="bi bi-trash-fill"></i>
                    </button>
                  <% } %>
                </div>
              <% } %>

            </div>
          <% }) %>
        </div>

        <div style="margin-top:18px; padding-top:14px; border-top:1px solid rgba(255,255,255,0.05); display:flex; justify-content:space-between; align-items:center">
          <span style="font-size:0.78rem; color:#374151"><span id="count-visivel"><%= usuarios.length %></span> usuário(s) exibido(s)</span>
          <span style="font-size:0.78rem; color:#374151">Total: <strong style="color:#94a3b8"><%= usuarios.length %></strong></span>
        </div>

      <% } %>
    </div>

  </main>

  <!-- Modal Ver Senha -->
  <div class="modal fade" id="modalSenha" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:440px">
      <div class="modal-content" style="border-radius:14px; border:1px solid rgba(99,102,241,0.2); background:#0f1624">
        <div class="modal-body p-4">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px">
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(99,102,241,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0">
              <i class="bi bi-key-fill" style="color:#818cf8; font-size:1.1rem"></i>
            </div>
            <div>
              <h5 style="margin:0; font-size:1rem; font-weight:700; color:#f1f5f9">Senha do usuário</h5>
              <div style="font-size:0.78rem; color:#64748b" id="modal-senha-nome"></div>
            </div>
          </div>
          <div style="font-size:0.75rem; color:#64748b; margin-bottom:6px">Senha:</div>
          <div class="senha-field" id="modal-senha-hash" style="font-size:0.95rem; color:#f1f5f9; letter-spacing:0.05em"></div>
        </div>
        <div class="modal-footer border-0 pt-0 px-4 pb-4">
          <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Fechar</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal Confirmar Exclusão -->
  <div class="modal fade" id="modalConfirmar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
      <div class="modal-content" style="border-radius:14px; border:1px solid rgba(239,68,68,0.2); background:#0f1624">
        <div class="modal-body p-4">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px">
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(239,68,68,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0">
              <i class="bi bi-exclamation-triangle-fill" style="color:#f87171; font-size:1.1rem"></i>
            </div>
            <h5 style="margin:0; font-size:1rem; font-weight:700; color:#f1f5f9">Confirmar exclusão</h5>
          </div>
          <p style="margin:0; font-size:0.875rem; color:#94a3b8; line-height:1.6">
            Deseja realmente excluir o usuário <strong id="modal-del-nome" style="color:#f1f5f9"></strong>? Esta ação não pode ser desfeita.
          </p>
        </div>
        <div class="modal-footer border-0 pt-0 px-4 pb-4" style="gap:10px">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="flex:1">Cancelar</button>
          <button type="button" class="btn btn-danger" id="btnConfirmarExcluir" style="flex:1">Excluir</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('busca-usuario').addEventListener('input', function() {
      const termo = this.value.toLowerCase();
      let visivel = 0;
      document.querySelectorAll('.user-row').forEach(function(row) {
        const match = row.dataset.busca.includes(termo);
        row.style.display = match ? '' : 'none';
        if (match) visivel++;
      });
      document.getElementById('count-visivel').textContent = visivel;
    });

    function verSenha(nome, hash) {
      document.getElementById('modal-senha-nome').textContent = nome;
      document.getElementById('modal-senha-hash').textContent = hash;
      new bootstrap.Modal(document.getElementById('modalSenha')).show();
    }

    var _idExcluir = null;
    var _modalConfirmar = null;

    function excluirUsuario(id, nome) {
      _idExcluir = id;
      document.getElementById('modal-del-nome').textContent = nome;
      _modalConfirmar = new bootstrap.Modal(document.getElementById('modalConfirmar'));
      _modalConfirmar.show();
    }

    document.getElementById('btnConfirmarExcluir').addEventListener('click', function() {
      if (!_idExcluir) return;
      fetch('/usuarios/' + _idExcluir, { method: 'DELETE' })
        .then(r => r.json())
        .then(data => {
          if (data.ok) { _modalConfirmar.hide(); location.reload(); }
        });
    });
  </script>

</body>
</html>

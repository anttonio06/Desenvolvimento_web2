<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Serviços - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
  <style>
    .tabela-servicos {
      width: 100%;
    }
    .tabela-servicos thead th {
      white-space: nowrap;
      text-align: center;
    }
    .tabela-servicos thead th:first-child {
      text-align: left;
    }
    .tabela-servicos tbody tr {
      height: 54px;
    }
    .tabela-servicos tbody td {
      vertical-align: middle;
      text-align: center;
      padding: 0 16px;
    }
    .tabela-servicos tbody td:first-child {
      text-align: left;
    }
    /* Corrige o display:flex do .acoes que quebra o vertical-align */
    .tabela-servicos tbody td.acoes {
      display: table-cell;
      vertical-align: middle;
      text-align: center;
    }
    .tabela-servicos tbody td.acoes .btn-acao {
      display: inline-flex;
      vertical-align: middle;
    }
    .tabela-servicos input[type="number"] {
      width: 80px;
      padding: 4px 8px;
      border: 1px solid transparent;
      border-radius: 6px;
      font-size: 0.875rem;
      background: transparent;
      color: #e0e0e0;
      text-align: center;
      vertical-align: middle;
    }
    .tabela-servicos input[type="number"]:disabled {
      background: transparent;
      border-color: transparent;
      color: #e0e0e0;
      cursor: default;
    }
    .tabela-servicos input[type="number"]:not(:disabled) {
      background: #0d1421;
      border-color: #10b981;
      outline: none;
      color: #f0f0f0;
      width: 90px;
    }
    .badge-porte {
      font-size: 0.75rem;
      font-weight: 600;
      color: #888888;
      display: block;
      margin-bottom: 2px;
    }
  </style>
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-scissors"></i> Serviços</div>
        <div class="page-subtitle">Ajuste os preços por porte para cada serviço oferecido</div>
      </div>
    </div>

    <% if (servicos.length === 0) { %>
      <div class="section-card">
        <div class="empty-state">
          <i class="bi bi-scissors"></i>
          Nenhum serviço encontrado. Reinicie o servidor para carregar os serviços padrão.
        </div>
      </div>
    <% } else { %>
    <div class="section-card">
      <table class="table-agendamentos tabela-servicos" id="tabela-servicos">
        <thead>
          <tr>
            <th>Serviço</th>
            <th>Duração (min)</th>
            <th><i class="bi bi-tag-fill" style="color:#22c55e"></i> Pequeno (R$)</th>
            <th><i class="bi bi-tag-fill" style="color:#f59e0b"></i> Médio (R$)</th>
            <th><i class="bi bi-tag-fill" style="color:#ef4444"></i> Grande (R$)</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% servicos.forEach(function(s) { %>
            <tr id="row-<%= s.id %>">
              <td><strong><%= s.nome %></strong></td>
              <td>
                <input type="number" min="1" value="<%= s.duracao_min || 60 %>" disabled data-campo="duracao_min">
              </td>
              <td>
                <input type="number" min="0" step="0.01" value="<%= Number(s.preco_pequeno || 0).toFixed(2) %>" disabled data-campo="preco_pequeno">
              </td>
              <td>
                <input type="number" min="0" step="0.01" value="<%= Number(s.preco_medio || 0).toFixed(2) %>" disabled data-campo="preco_medio">
              </td>
              <td>
                <input type="number" min="0" step="0.01" value="<%= Number(s.preco_grande || 0).toFixed(2) %>" disabled data-campo="preco_grande">
              </td>
              <td class="acoes">
                <button class="btn-acao editar btn-editar-<%= s.id %>" title="Editar" onclick="editarServico(<%= s.id %>)">
                  <i class="bi bi-pencil-fill"></i>
                </button>
                <button class="btn-acao salvar btn-salvar btn-salvar-<%= s.id %>" title="Salvar" onclick="salvarServico(<%= s.id %>)" style="background:#10b981; color:#fff; display:none; padding:6px 14px; gap:6px">
                  <i class="bi bi-check-lg"></i>
                </button>
                <button class="btn-acao btn-cancelar btn-cancelar-<%= s.id %>" title="Cancelar" onclick="cancelarEdicao(<%= s.id %>)" style="background:#3a3a3a; color:#aaaaaa; display:none">
                  <i class="bi bi-x-lg"></i>
                </button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>

    <div id="toast-sucesso" style="display:none; position:fixed; bottom:24px; right:24px; background:#10b981; color:#fff; padding:12px 22px; border-radius:10px; font-weight:600; z-index:9999; box-shadow:0 4px 16px rgba(16,185,129,0.3);">
      <i class="bi bi-check-circle-fill"></i> A alteração foi realizada!
    </div>
    <div id="toast-erro" style="display:none; position:fixed; bottom:24px; right:24px; background:#ef4444; color:#fff; padding:12px 22px; border-radius:10px; font-weight:600; z-index:9999; box-shadow:0 4px 16px rgba(0,0,0,0.15);">
      <i class="bi bi-x-circle-fill"></i> Erro ao salvar. Tente novamente.
    </div>

  </main>

  <script>
    const valoresOriginais = {};

    function editarServico(id) {
      const row = document.getElementById('row-' + id);
      const inputs = row.querySelectorAll('input');

      valoresOriginais[id] = Array.from(inputs).map(i => i.value);

      inputs.forEach(i => i.disabled = false);
      document.querySelector('.btn-editar-' + id).style.display = 'none';
      document.querySelector('.btn-salvar-' + id).style.display = 'inline-flex';
      document.querySelector('.btn-cancelar-' + id).style.display = 'inline-flex';
    }

    function cancelarEdicao(id) {
      const row = document.getElementById('row-' + id);
      const inputs = row.querySelectorAll('input');

      if (valoresOriginais[id]) {
        inputs.forEach((inp, i) => inp.value = valoresOriginais[id][i]);
      }
      inputs.forEach(i => i.disabled = true);
      document.querySelector('.btn-editar-' + id).style.display = '';
      document.querySelector('.btn-salvar-' + id).style.display = 'none';
      document.querySelector('.btn-cancelar-' + id).style.display = 'none';
    }

    function salvarServico(id) {
      const row = document.getElementById('row-' + id);
      const dados = {};
      row.querySelectorAll('input').forEach(inp => {
        dados[inp.dataset.campo] = inp.value;
      });

      fetch('/servicos/' + id, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(dados)
      })
      .then(res => res.json())
      .then(data => {
        if (data.ok) {
          row.querySelectorAll('input').forEach(i => i.disabled = true);
          document.querySelector('.btn-editar-' + id).style.display = '';
          document.querySelector('.btn-salvar-' + id).style.display = 'none';
          document.querySelector('.btn-cancelar-' + id).style.display = 'none';
          mostrarToast('sucesso');
        } else {
          mostrarToast('erro');
        }
      })
      .catch(() => mostrarToast('erro'));
    }

    function mostrarToast(tipo) {
      const el = document.getElementById('toast-' + tipo);
      el.style.display = 'block';
      setTimeout(() => { el.style.display = 'none'; }, 3000);
    }
  </script>

</body>
</html>

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agendamentos - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-calendar2-week-fill"></i> Agendamentos</div>
        <div class="page-subtitle">Gerencie todos os agendamentos</div>
      </div>
      <button class="btn-primary-action" onclick="window.location.href='/agendamentos/novo'">
        <i class="bi bi-plus-lg"></i> Novo Agendamento
      </button>
    </div>

    <!-- Filtros de status -->
    <div class="filter-bar">
      <button class="filter-btn" data-status="todos">Todos</button>
      <button class="filter-btn active" data-status="confirmado">Agendados</button>
      <button class="filter-btn" data-status="concluido">Concluídos</button>
      <button class="filter-btn" data-status="cancelado">Cancelados</button>
    </div>

    <div class="section-card">
      <div class="search-bar">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar por cliente, pet ou serviço..." id="busca-agendamento">
      </div>

      <table class="table-agendamentos" id="tabela-agendamentos">
        <thead>
          <tr>
            <th>Data / Hora</th>
            <th>Cliente</th>
            <th>Pet</th>
            <th>Serviço</th>
            <th>Funcionário</th>
            <th>Valor</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (agendamentos.length === 0) { %>
            <tr>
              <td colspan="8">
                <div class="empty-state">
                  <i class="bi bi-calendar2-x"></i>
                  Nenhum agendamento cadastrado ainda.
                </div>
              </td>
            </tr>
          <% } else { %>
            <% agendamentos.forEach(function(a) { %>
              <tr data-status="<%= a.status %>">
                <td><strong><%= new Date(a.data_hora).toLocaleDateString('pt-BR') %></strong><br><small style="color:#4a4a62; font-size:0.72rem"><%= new Date(a.data_hora).toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'}) %></small></td>
                <td><%= a.cliente_nome %></td>
                <td><%= a.pet_nome %></td>
                <td><%= a.servicos_nomes || a.servico_nome || '—' %></td>
                <td><%= a.funcionario_nome || '—' %></td>
                <td><%= a.valor ? 'R$ ' + Number(a.valor).toFixed(2).replace('.', ',') : '—' %></td>
                <td>
                  <% if (a.status === 'confirmado') { %><span class="badge-status badge-confirmado">Agendado</span>
                  <% } else if (a.status === 'pendente') { %><span class="badge-status badge-pendente">Pendente</span>
                  <% } else if (a.status === 'concluido') { %><span class="badge-status badge-concluido">Concluído</span>
                  <% } else { %><span class="badge-status badge-cancelado">Cancelado</span>
                  <% } %>
                </td>
                <td class="acoes">
                  <button class="btn-acao" title="Marcar como concluído" onclick="concluir(<%= a.id %>)"
                    style="background:rgba(16,185,129,0.08);color:#10b981;border:1px solid rgba(16,185,129,0.2);<%- (a.status === 'concluido' || a.status === 'cancelado') ? 'visibility:hidden;pointer-events:none' : '' %>">
                    <i class="bi bi-check-lg"></i>
                  </button>
                  <a href="/agendamentos/<%= a.id %>/editar" class="btn-acao editar" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                  <button class="btn-acao excluir" title="Excluir" onclick="excluir('/agendamentos/<%= a.id %>')"><i class="bi bi-trash-fill"></i></button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>

      <% if (totalPaginas > 1) { %>
        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:18px;padding-top:14px;border-top:1px solid rgba(255,255,255,0.05);">
          <span style="font-size:0.78rem;color:#4b5563;">
            Mostrando página <%= pagina %> de <%= totalPaginas %> &nbsp;·&nbsp; <%= total %> agendamentos no total
          </span>
          <div style="display:flex;gap:6px;">
            <% if (pagina > 1) { %>
              <a href="/agendamentos?pagina=<%= pagina - 1 %>" style="display:inline-flex;align-items:center;padding:6px 12px;border-radius:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);color:#94a3b8;font-size:0.8rem;text-decoration:none;">
                <i class="bi bi-chevron-left"></i>&nbsp; Anterior
              </a>
            <% } %>
            <% if (pagina < totalPaginas) { %>
              <a href="/agendamentos?pagina=<%= pagina + 1 %>" style="display:inline-flex;align-items:center;padding:6px 12px;border-radius:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);color:#94a3b8;font-size:0.8rem;text-decoration:none;">
                Próxima &nbsp;<i class="bi bi-chevron-right"></i>
              </a>
            <% } %>
          </div>
        </div>
      <% } %>

    </div>

  </main>

  <!-- Modal Confirmação Exclusão -->
  <div class="modal fade" id="modalConfirmar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width:420px">
      <div class="modal-content" style="border-radius:14px; border:1px solid rgba(239,68,68,0.2); background:#0f1624">
        <div class="modal-body p-4">
          <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px">
            <div style="width:40px; height:40px; border-radius:10px; background:rgba(239,68,68,0.1); display:flex; align-items:center; justify-content:center; flex-shrink:0">
              <i class="bi bi-exclamation-triangle-fill" style="color:#f87171; font-size:1.1rem"></i>
            </div>
            <h5 style="margin:0; font-size:1rem; font-weight:700; color:#f1f5f9">Confirmar exclusão</h5>
          </div>
          <p style="margin:0; font-size:0.875rem; color:#94a3b8; line-height:1.6">Deseja realmente excluir este agendamento? Esta ação não pode ser desfeita.</p>
        </div>
        <div class="modal-footer border-0 pt-0 px-4 pb-4" style="gap:10px">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="flex:1">Cancelar</button>
          <button type="button" class="btn btn-danger" id="btnConfirmarExcluir" style="flex:1">Excluir</button>
        </div>
      </div>
    </div>
  </div>

  <% if (typeof sucesso !== 'undefined' && sucesso) { %>
  <div id="toast-sucesso" style="position:fixed;bottom:28px;right:28px;z-index:9999;display:flex;align-items:center;gap:10px;background:#0f1f17;border:1px solid rgba(16,185,129,0.3);border-radius:12px;padding:14px 18px;box-shadow:0 8px 32px rgba(0,0,0,0.4);min-width:260px;">
    <div style="width:32px;height:32px;border-radius:8px;background:rgba(16,185,129,0.15);display:flex;align-items:center;justify-content:center;flex-shrink:0">
      <i class="bi bi-check-circle-fill" style="color:#10b981;font-size:1rem"></i>
    </div>
    <span style="font-size:0.875rem;font-weight:500;color:#f1f5f9;">
      <%= sucesso === 'criado' ? 'Agendamento criado com sucesso!' : sucesso === 'concluido' ? 'Serviço finalizado!' : 'Agendamento atualizado com sucesso!' %>
    </span>
  </div>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.querySelectorAll('#tabela-agendamentos tbody tr[data-status]').forEach(function(tr) {
      if (tr.dataset.status !== 'confirmado') tr.style.display = 'none';
    });

    var toast = document.getElementById('toast-sucesso');
    if (toast) {
      setTimeout(function() {
        toast.style.transition = 'opacity 0.4s';
        toast.style.opacity = '0';
        setTimeout(function() { toast.remove(); }, 400);
      }, 3000);
    }

    var _urlExcluir = null;
    var _modalConfirmar = null;

    document.getElementById('busca-agendamento').addEventListener('input', function() {
      var termo = this.value.toLowerCase();
      document.querySelectorAll('#tabela-agendamentos tbody tr').forEach(function(tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    });

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        var status = this.dataset.status;
        document.querySelectorAll('#tabela-agendamentos tbody tr[data-status]').forEach(function(tr) {
          tr.style.display = (status === 'todos' || tr.dataset.status === status) ? '' : 'none';
        });
      });
    });

    function concluir(id) {
      fetch('/agendamentos/' + id + '/concluir', { method: 'POST' })
        .then(function(r) { return r.json(); })
        .then(function(data) { if (data.ok) window.location.href = '/agendamentos?sucesso=concluido'; });
    }

    function excluir(url) {
      _urlExcluir = url;
      _modalConfirmar = new bootstrap.Modal(document.getElementById('modalConfirmar'));
      _modalConfirmar.show();
    }

    document.getElementById('btnConfirmarExcluir').addEventListener('click', function() {
      if (_urlExcluir) {
        fetch(_urlExcluir, { method: 'DELETE' }).then(function() {
          _modalConfirmar.hide();
          location.reload();
        });
      }
    });
  </script>

</body>
</html>

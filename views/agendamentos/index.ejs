<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Agendamentos - PetAgenda</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/dashboard.css">
  <link rel="stylesheet" href="/css/pages.css">
</head>
<body>

  <%- include('../partials/sidebar') %>

  <main class="main-content">

    <div class="page-header">
      <div>
        <div class="page-title"><i class="bi bi-calendar2-week-fill"></i> Agendamentos</div>
        <div class="page-subtitle">Gerencie todos os agendamentos</div>
      </div>
      <button class="btn-primary-action">
        <i class="bi bi-plus-lg"></i> Novo Agendamento
      </button>
    </div>

    <!-- Filtros de status -->
    <div class="filter-bar">
      <button class="filter-btn active" data-status="todos">Todos</button>
      <button class="filter-btn" data-status="confirmado">Confirmados</button>
      <button class="filter-btn" data-status="pendente">Pendentes</button>
      <button class="filter-btn" data-status="concluido">Concluídos</button>
      <button class="filter-btn" data-status="cancelado">Cancelados</button>
    </div>

    <div class="section-card">
      <div class="search-bar">
        <i class="bi bi-search"></i>
        <input type="text" placeholder="Buscar por cliente, pet ou serviço..." id="busca-agendamento">
      </div>

      <table class="table-agendamentos" id="tabela-agendamentos">
        <thead>
          <tr>
            <th>#</th>
            <th>Data / Hora</th>
            <th>Cliente</th>
            <th>Pet</th>
            <th>Serviço</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody>
          <% if (agendamentos.length === 0) { %>
            <tr>
              <td colspan="7">
                <div class="empty-state">
                  <i class="bi bi-calendar2-x"></i>
                  Nenhum agendamento cadastrado ainda.
                </div>
              </td>
            </tr>
          <% } else { %>
            <% agendamentos.forEach(function(a) { %>
              <tr data-status="<%= a.status %>">
                <td><%= a.id %></td>
                <td><strong><%= new Date(a.data_hora).toLocaleDateString('pt-BR') %></strong><br><small style="color:#9ca3af"><%= new Date(a.data_hora).toLocaleTimeString('pt-BR', {hour:'2-digit', minute:'2-digit'}) %></small></td>
                <td><%= a.cliente_nome %></td>
                <td><%= a.pet_nome %></td>
                <td><%= a.servico_nome %></td>
                <td>
                  <% if (a.status === 'confirmado') { %><span class="badge-status badge-confirmado">Confirmado</span>
                  <% } else if (a.status === 'pendente') { %><span class="badge-status badge-pendente">Pendente</span>
                  <% } else if (a.status === 'concluido') { %><span class="badge-status badge-concluido">Concluído</span>
                  <% } else { %><span class="badge-status badge-cancelado">Cancelado</span>
                  <% } %>
                </td>
                <td class="acoes">
                  <a href="/agendamentos/<%= a.id %>" class="btn-acao editar" title="Editar"><i class="bi bi-pencil-fill"></i></a>
                  <button class="btn-acao excluir" title="Excluir" onclick="excluir('/agendamentos/<%= a.id %>')"><i class="bi bi-trash-fill"></i></button>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>

  </main>

  <script>
    document.getElementById('busca-agendamento').addEventListener('input', function() {
      var termo = this.value.toLowerCase();
      document.querySelectorAll('#tabela-agendamentos tbody tr').forEach(function(tr) {
        tr.style.display = tr.textContent.toLowerCase().includes(termo) ? '' : 'none';
      });
    });

    document.querySelectorAll('.filter-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        this.classList.add('active');
        var status = this.dataset.status;
        document.querySelectorAll('#tabela-agendamentos tbody tr[data-status]').forEach(function(tr) {
          tr.style.display = (status === 'todos' || tr.dataset.status === status) ? '' : 'none';
        });
      });
    });

    function excluir(url) {
      if (confirm('Deseja excluir este agendamento?')) {
        fetch(url, { method: 'DELETE' }).then(function() { location.reload(); });
      }
    }
  </script>

</body>
</html>

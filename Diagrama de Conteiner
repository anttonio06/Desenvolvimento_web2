@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Diagrama de Contêineres - PetAgenda

LAYOUT_TOP_DOWN()

Person(atendente, "Atendente", "Gerencia clientes, pets e agendamentos no pet shop.")
Person(admin, "Administrador", "Administra serviços, usuários e o funcionamento geral do sistema.")

System_Boundary(petagenda, "PetAgenda") {
    Container(app, "Aplicação Web", "Node.js, Express, EJS, Bootstrap", "Renderiza páginas no servidor (SSR) e implementa as regras de negócio: autenticação, CRUD de clientes/pets/serviços, criação de agendamentos com validação de conflito e controle de status.")

    ContainerDb(db, "Banco de Dados", "SQLite", "Armazena usuários, clientes, pets, serviços e agendamentos.")
}

Rel(atendente, app, "Acessa pelo navegador", "HTTPS")
Rel(admin, app, "Acessa pelo navegador", "HTTPS")

Rel(app, db, "Lê e grava dados", "SQL")

@enduml